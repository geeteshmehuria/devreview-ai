# API base URL of the backend.
# Local: http://localhost:8000
# Production: your Render URL, e.g. https://devreview-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public URL of this frontend.
# Local: http://localhost:3000
# Production: your Vercel URL, e.g. https://devreview-ai.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth client id (public — the secret lives only on the backend).
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-oauth-client-id
