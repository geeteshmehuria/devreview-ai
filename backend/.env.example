# Application
APP_NAME=DevReview AI
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALLOWED_ORIGINS=http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://devreview:devreview_secret@localhost:5432/devreview_ai

# Redis
REDIS_URL=redis://:redis_secret@localhost:6379/0
REDIS_PASSWORD=redis_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/callback

# AI Providers (Gemini is primary)
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key-optional
ANTHROPIC_API_KEY=your-anthropic-api-key-optional
AI_PRIMARY_PROVIDER=gemini

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Celery
CELERY_BROKER_URL=redis://:redis_secret@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@localhost:6379/2

# Cache TTL (seconds)
CACHE_TTL_REPO_ANALYSIS=3600
CACHE_TTL_PR_REVIEW=1800
CACHE_TTL_CODE_REVIEW=900
